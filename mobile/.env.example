# Copy to .env and set to your PC's LAN IP so Expo Go can reach the backend.
# DEV: your PC's LAN IP. PROD: your public API, e.g. https://huberleon.com
EXPO_PUBLIC_API_URL=http://YOUR_PC_LAN_IP:8000

# Social login (Google/GitHub/Discord) — same as the web. Set these to your
# Supabase Cloud project (prod) to enable the social buttons on the login screen.
# Leave blank in dev (the buttons are hidden when unset). The anon key is public.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
