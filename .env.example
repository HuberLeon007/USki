# === APP MODE ===
# "dev" = local Supabase + Ollama (no internet needed)
# "prod" = Supabase Cloud + external AI provider
APP_MODE=dev

# ── Supabase ──
# DEV: use values from `supabase start` output
# PROD: use values from Supabase Cloud dashboard
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Backend ──
BACKEND_CORS_ORIGINS=http://localhost:5173
BACKEND_LOG_LEVEL=INFO

# ── AI Provider ──
# DEV: leave empty -> auto-resolves to local Ollama (qwen3:4b)
# PROD: set these to your provider
AI_BASE_URL=
AI_API_KEY=ollama
AI_MODEL=

# ── Rate Limiting ──
RATE_LIMIT_REDIS_URL=redis://localhost:6379
RATE_LIMIT_SEND_OTP_IP=5/minute
RATE_LIMIT_VERIFY_OTP_IP=10/minute