# === APP MODE ===
# "dev"  = local Supabase + local Ollama (no internet needed, single GPU box)
# "prod" = Supabase Cloud + external AI providers (see AI_PROVIDERS_FILE below)
APP_MODE=dev

# ── Supabase ──
# DEV: use values from `supabase start` output
# PROD: use values from the Supabase Cloud dashboard
SUPABASE_URL=http://127.0.0.1:54321
# Browser-facing URL = token issuer. Only needed when the backend reaches
# Supabase on a different host than the browser (e.g. Docker: backend uses
# host.docker.internal, browser uses 127.0.0.1). Empty -> falls back to SUPABASE_URL.
SUPABASE_PUBLIC_URL=
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Backend ──
BACKEND_CORS_ORIGINS=http://localhost:5173
BACKEND_LOG_LEVEL=INFO

# ─────────────────────────────────────────────────────────────────────────
# AI — DEV (local Ollama)
# In dev the chat + embeddings always run on the local Ollama (wired in
# docker-compose.yml as AI_BASE_URL=http://ollama:11434/v1). You only pick the
# models here; everything else is fixed. Models are auto-pulled by ollama-init.
# Ollama runtime tuning (keep-alive forever, parallelism, context, flash attn)
# lives in docker-compose.yml under the `ollama` service.
# ─────────────────────────────────────────────────────────────────────────
AI_BASE_URL=
AI_API_KEY=ollama
AI_MODEL=gemma3:4b
AI_EMBED_MODEL=nomic-embed-text

# ─────────────────────────────────────────────────────────────────────────
# AI — PROD (external providers, load-balanced)
# Set APP_MODE=prod and point AI_PROVIDERS_FILE at a JSON pool of
# OpenAI-compatible chat endpoints. The backend round-robins across them so
# several free-tier keys/limits add up and run in parallel. See
# ai_providers.example.json. Ignored in dev. If the file is missing it falls
# back to the single AI_BASE_URL / AI_MODEL above.
# ─────────────────────────────────────────────────────────────────────────
AI_PROVIDERS_FILE=ai_providers.json

# ── Rate Limiting ──
RATE_LIMIT_REDIS_URL=redis://redis:6379
RATE_LIMIT_SEND_OTP_IP=5/minute
RATE_LIMIT_VERIFY_OTP_IP=10/minute
