# === APP MODE ===
# "dev"  = local Supabase + local Ollama (no internet needed, single GPU box).
#          Social login uses the offline mock path (the buttons mint a local
#          Supabase session for a per-provider mock identity, no external call).
# "prod" = Supabase Cloud + external AI providers (see AI_PROVIDERS_FILE below).
#          Social login uses the real Google/GitHub/Discord OAuth via Supabase.
# The mode alone decides this; there is no separate mock flag. The mock adapter
# is dropped from prod builds, so it can never run in production.
APP_MODE=dev

# ── Supabase ──
# DEV: use values from `supabase start` output
# PROD: use values from the Supabase Cloud dashboard
SUPABASE_URL=http://127.0.0.1:54321
# Browser-facing URL = token issuer. Only needed when the backend reaches
# Supabase on a different host than the browser (e.g. Docker: backend uses
# host.docker.internal, browser uses 127.0.0.1). Empty -> falls back to SUPABASE_URL.
SUPABASE_PUBLIC_URL=
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Social login provider OAuth credentials (NOT used by this repo directly) ──
# Google / GitHub / Discord client id + secret are entered into Supabase Auth,
# never read from this file by the app:
#   PROD : Supabase Cloud dashboard -> Authentication -> Providers
#   DEV  : supabase/config.toml [auth.external.<provider>] via env(...) indirection
# The values below are only the env vars that supabase/config.toml references for
# LOCAL dev. Leave them unset unless you enable a provider locally. Real secrets
# live in your shell env or Supabase only and are NEVER committed (see PROVIDERS.md).
# SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=
# SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=
# SUPABASE_AUTH_EXTERNAL_GITHUB_CLIENT_ID=
# SUPABASE_AUTH_EXTERNAL_GITHUB_SECRET=
# SUPABASE_AUTH_EXTERNAL_DISCORD_CLIENT_ID=
# SUPABASE_AUTH_EXTERNAL_DISCORD_SECRET=

# ── Backend ──
BACKEND_CORS_ORIGINS=http://localhost:5173
BACKEND_LOG_LEVEL=INFO

# ─────────────────────────────────────────────────────────────────────────
# AI — DEV (local Ollama)
# In dev the chat + embeddings always run on the local Ollama (wired in
# docker-compose.yml as AI_BASE_URL=http://ollama:11434/v1). You only pick the
# models here; everything else is fixed. Models are auto-pulled by ollama-init.
# Ollama runtime tuning (keep-alive forever, parallelism, context, flash attn)
# lives in docker-compose.yml under the `ollama` service.
# ─────────────────────────────────────────────────────────────────────────
AI_BASE_URL=
AI_API_KEY=ollama
AI_MODEL=gemma3:4b
AI_EMBED_MODEL=nomic-embed-text

# ─────────────────────────────────────────────────────────────────────────
# AI — PROD (external providers, load-balanced)
# Set APP_MODE=prod and point AI_PROVIDERS_FILE at a JSON pool of
# OpenAI-compatible chat endpoints. The backend round-robins across them so
# several free-tier keys/limits add up and run in parallel. See
# ai_providers.example.json. Ignored in dev. If the file is missing it falls
# back to the single AI_BASE_URL / AI_MODEL above.
# ─────────────────────────────────────────────────────────────────────────
AI_PROVIDERS_FILE=ai_providers.json

# ── Rate Limiting ──
RATE_LIMIT_REDIS_URL=redis://redis:6379
RATE_LIMIT_SEND_OTP_IP=5/minute
RATE_LIMIT_VERIFY_OTP_IP=10/minute

# ─────────────────────────────────────────────────────────────────────────
# PROD-ONLY (school-server deploy: huberleon.com via Cloudflare Tunnel +
# Supabase Cloud). Leave blank/ignored in dev. Full runbook: PRODUCTION.md
# For prod set APP_MODE=prod, SUPABASE_URL + SUPABASE_PUBLIC_URL = your
# https://YOUR-REF.supabase.co (EU region) + the cloud keys above. AI_BASE_URL
# stays blank (compose points it at ollama); AI_EMBED_MODEL stays nomic-embed-text.
# ─────────────────────────────────────────────────────────────────────────

# Transactional email (Resend). Verify huberleon.com, sender on that domain,
# and set the SAME SMTP in Supabase (Auth -> SMTP) for OTP mails.
RESEND_API_KEY=
EMAIL_FROM=USki <noreply@huberleon.com>

# Passkeys / WebAuthn — must match the public domain in prod (blank in dev).
WEBAUTHN_RP_ID=
WEBAUTHN_RP_NAME=USki
WEBAUTHN_ORIGINS=

# Cloudflare Tunnel token (Zero Trust -> Networks -> Tunnels -> your tunnel).
CLOUDFLARE_TUNNEL_TOKEN=

# Backend worker count (prod). Optional.
UVICORN_WORKERS=2
