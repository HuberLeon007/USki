% Minimal modern beamer style for USki presentations
% Optimized for LuaLaTeX, backward-compatible with pdfLaTeX
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{uski-beamer}[2025/06/10 v1.0 USki Beamer Style]

% Font handling
\RequirePackage{ifluatex}
\ifluatex
  \RequirePackage{fontspec}
  \defaultfontfeatures{Ligatures=TeX,Scale=MatchLowercase}
  % Latin Modern OTF covers full Unicode -- no more missing glyphs
\else
  \RequirePackage[T1]{fontenc}
  \RequirePackage[utf8]{inputenc}
\fi

% Language & Typography
\RequirePackage[ngerman]{babel}
\RequirePackage{amsmath,amssymb,amsthm}
\RequirePackage{microtype}

% Graphics & Diagrams
\RequirePackage{graphicx}
\RequirePackage{tikz}
\usetikzlibrary{calc,positioning,shapes.geometric,arrows.meta,fit,backgrounds}

% Tables & Code
\RequirePackage{booktabs}
\RequirePackage{listings}

% Layout helpers
\RequirePackage{multicol}

% ------------------------------------------------------------------
% Color Palette (flat, minimal)
% ------------------------------------------------------------------
\definecolor{primary}{HTML}{1A1A1A}    % near-black
\definecolor{accent}{HTML}{2563EB}     % modern blue
\definecolor{graytext}{HTML}{6B7280}   % warm gray
\definecolor{lightgray}{HTML}{F3F4F6}  % background gray
\definecolor{alertred}{HTML}{DC2626}   % soft red
\definecolor{codebg}{HTML}{F8FAFC}     % code background
\definecolor{codeframe}{HTML}{E2E8F0}  % code frame

% ------------------------------------------------------------------
% Beamer core: strip away defaults for a clean look
% ------------------------------------------------------------------
\usetheme{default}
\usecolortheme{default}

\setbeamertemplate{navigation symbols}{}
\setbeamertemplate{headline}{}
\setbeamertemplate{footline}[frame number]

% ------------------------------------------------------------------
% Font settings
% ------------------------------------------------------------------
\setbeamerfont{title}{series=\bfseries,size=\LARGE}
\setbeamerfont{frametitle}{series=\bfseries,size=\Large}
\setbeamerfont{framesubtitle}{series=\mdseries,size=\normalsize}
\setbeamerfont{footnote}{size=\tiny}

% ------------------------------------------------------------------
% Color settings
% ------------------------------------------------------------------
\setbeamercolor{background canvas}{bg=white}
\setbeamercolor{normal text}{fg=primary}
\setbeamercolor{frametitle}{fg=primary}
\setbeamercolor{framesubtitle}{fg=graytext}
\setbeamercolor{title}{fg=primary}
\setbeamercolor{subtitle}{fg=graytext}
\setbeamercolor{author}{fg=graytext}
\setbeamercolor{date}{fg=graytext}
\setbeamercolor{institute}{fg=graytext}
\setbeamercolor{item}{fg=accent}
\setbeamercolor{block title}{bg=lightgray,fg=primary}
\setbeamercolor{block body}{bg=lightgray,fg=primary}
\setbeamercolor{block title example}{bg=lightgray,fg=accent}
\setbeamercolor{block body example}{bg=lightgray,fg=primary}
\setbeamercolor{block title alerted}{bg=white,fg=alertred}
\setbeamercolor{block body alerted}{bg=lightgray,fg=primary}
\setbeamercolor{footline}{fg=graytext}

% ------------------------------------------------------------------
% Item templates
% ------------------------------------------------------------------
\setbeamertemplate{itemize item}{\scriptsize$\bullet$}
\setbeamertemplate{itemize subitem}{\scriptsize$\circ$}
\setbeamertemplate{enumerate item}[default]
\setbeamertemplate{enumerate subitem}[default]

% ------------------------------------------------------------------
% Title page layout
% ------------------------------------------------------------------
\setbeamertemplate{title page}{%
  \vfill
  \begin{center}
    {\usebeamerfont{title}\usebeamercolor[fg]{title}\inserttitle}
    \vspace{4pt}

    {\usebeamerfont{subtitle}\usebeamercolor[fg]{subtitle}\insertsubtitle}
    \vspace{20pt}

    {\usebeamerfont{author}\usebeamercolor[fg]{author}\insertauthor}
    \vspace{4pt}

    {\usebeamerfont{date}\usebeamercolor[fg]{date}\insertdate}
  \end{center}
  \vfill
}

% ------------------------------------------------------------------
% Frametitle with accent underline
% ------------------------------------------------------------------
\setbeamertemplate{frametitle}{%
  \vspace{10pt}
  \usebeamerfont{frametitle}\usebeamercolor[fg]{frametitle}\insertframetitle
  \ifx\insertframesubtitle\empty\else
    \newline
    {\usebeamerfont{framesubtitle}\usebeamercolor[fg]{framesubtitle}\insertframesubtitle}
  \fi
  \vspace{2pt}
  {\color{accent}\rule[0mm]{\dimexpr\paperwidth-30pt\relax}{1pt}}
  \vspace{-4pt}
}

% ------------------------------------------------------------------
% Code listings style
% ------------------------------------------------------------------
\lstdefinestyle{uski}{%
  backgroundcolor=\color{codebg},
  basicstyle=\ttfamily\footnotesize\color{primary},
  breakatwhitespace=false,
  breaklines=true,
  captionpos=b,
  commentstyle=\color{graytext},
  frame=single,
  rulecolor=\color{codeframe},
  keepspaces=true,
  keywordstyle=\color{accent}\bfseries,
  numbers=none,
  showspaces=false,
  showstringspaces=false,
  showtabs=false,
  stringstyle=\color{alertred},
  tabsize=2,
  aboveskip=6pt,
  belowskip=6pt,
  xleftmargin=4pt,
  xrightmargin=4pt,
}
\lstset{style=uski}

% ------------------------------------------------------------------
% TikZ presets for architecture diagrams
% ------------------------------------------------------------------
\tikzset{
  node distance=1.2cm,
  box/.style={rectangle, rounded corners=4pt, draw=codeframe, fill=codebg, minimum width=2.5cm, minimum height=0.9cm, align=center, font=\small},
  accentbox/.style={rectangle, rounded corners=4pt, draw=accent, fill=lightgray, minimum width=2.5cm, minimum height=0.9cm, align=center, font=\small\bfseries},
  arrow/.style={-{Stealth[length=3mm]}, thick, primary},
  mylabel/.style={font=\footnotesize\color{graytext}}
}
