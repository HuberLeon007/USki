# ─────────────────────────────────────────────────────────────────────────
# USki PRODUCTION env (school server + Cloudflare Tunnel + Supabase Cloud).
# Copy to `.env` ON THE SERVER, fill in real values, then: chmod 600 .env
# NEVER commit the filled-in .env or ai_providers.json.
# ─────────────────────────────────────────────────────────────────────────

# Prod mode: real OAuth (Google/GitHub/Discord via Supabase), chat via provider
# pool. The social mock path is dropped from the build.
APP_MODE=prod

# ── Supabase Cloud (create the project in an EU region, e.g. Frankfurt) ──
# Both URLs are the SAME public cloud URL in this setup (one origin). The public
# URL is also the JWT issuer the browser's token carries.
SUPABASE_URL=https://YOUR-REF.supabase.co
SUPABASE_PUBLIC_URL=https://YOUR-REF.supabase.co
SUPABASE_ANON_KEY=your-cloud-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-cloud-service-role-key   # SECRET — server only

# ── Backend ──
# Same-origin via Caddy, but set the public origin explicitly for safety.
BACKEND_CORS_ORIGINS=https://huberleon.com
BACKEND_LOG_LEVEL=INFO

# ── AI: embeddings (local Ollama on the server, 768-dim — do NOT change) ──
AI_EMBED_MODEL=nomic-embed-text
# AI_BASE_URL is set by docker-compose.prod.yml to the ollama sibling; leave blank.
AI_BASE_URL=
AI_API_KEY=ollama

# ── AI: chat (external provider pool, round-robin) ──
# REQUIRED in prod: copy ai_providers.example.json -> ai_providers.json and fill
# real free-tier keys (groq / gemini / openrouter). Without it, chat has no model
# (only the embedding model is pulled locally). See ai_providers.example.json.
AI_PROVIDERS_FILE=ai_providers.json

# ── Transactional email (Resend) ──
# Verify huberleon.com in Resend, then use a sender on that domain. Also set this
# same SMTP in the Supabase dashboard (Auth → SMTP) so OTP login mails are not
# rate-limited by Supabase's shared sender.
RESEND_API_KEY=your-resend-api-key
EMAIL_FROM=USki <noreply@huberleon.com>

# ── Passkeys / WebAuthn (must match the public domain) ──
WEBAUTHN_RP_ID=huberleon.com
WEBAUTHN_RP_NAME=USki
WEBAUTHN_ORIGINS=https://huberleon.com

# ── Rate limiting (Redis sibling) ──
RATE_LIMIT_REDIS_URL=redis://redis:6379
RATE_LIMIT_SEND_OTP_IP=5/minute
RATE_LIMIT_VERIFY_OTP_IP=10/minute

# ── Cloudflare Tunnel ──
# Token from: Cloudflare Zero Trust → Networks → Tunnels → (your tunnel) → token.
CLOUDFLARE_TUNNEL_TOKEN=your-cloudflared-tunnel-token

# ── Backend workers (optional tuning) ──
UVICORN_WORKERS=2
